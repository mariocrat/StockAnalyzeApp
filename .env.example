# AlphaMate backend environment example.
# Copy this to .env only on the server/development machine and fill real values there.
# Never put real API keys or secrets in Git.

# development | production
ALPHAMATE_ENV=development

# Server-side only. Do not expose this through VITE_* variables.
OPENAI_API_KEY=replace_with_server_secret
OPENAI_BASIC_REVIEW_MODEL=gpt-5.4-mini
OPENAI_ADVANCED_REVIEW_MODEL=gpt-5.5
# AI review traffic safety. Tune these for server/API budget.
ALPHAMATE_AI_REVIEW_RATE_LIMIT_PER_MINUTE=10
ALPHAMATE_AI_REVIEW_MAX_CONCURRENT=3
ALPHAMATE_AI_REVIEW_IDEMPOTENCY_TTL_SECONDS=300
ALPHAMATE_JOURNAL_ONCE_MAX_TRADES=500
ALPHAMATE_AI_REVIEW_MAX_TRADES=100
ALPHAMATE_JOURNAL_MEMO_MAX_CHARS=2000
ALPHAMATE_JOURNAL_QUERY_MAX_LIMIT=500
ALPHAMATE_SAVED_JOURNAL_ANALYSIS_MAX_TRADES=500
ALPHAMATE_OPENAI_TIMEOUT_SECONDS=45
ALPHAMATE_OPENAI_MAX_RETRIES=1
ALPHAMATE_OPENAI_RETRY_BACKOFF_SECONDS=0.5

# Local development only. These are ignored when ALPHAMATE_ENV=production.
ALPHAMATE_ALLOW_DEV_ACCESS=true
ALPHAMATE_DEV_AUTH_TOKEN=dev-token
ALPHAMATE_DEV_AD_REWARD_TOKEN=dev-ad-reward
ALPHAMATE_DEV_PRO_ENTITLEMENT_TOKEN=dev-pro-entitlement
ALPHAMATE_ALLOW_ADVANCED_TICKET_FOR_BASIC=false
ALPHAMATE_ADS_PER_ADVANCED_TICKET=5
ALPHAMATE_FORCE_REWARDED_AD_CHAIN=false

# Comma-separated browser/WebView origins allowed to call the backend.
# Defaults include local Vite preview/dev and Capacitor WebView origins.
# ALPHAMATE_CORS_ORIGINS=https://your-app.example.com,capacitor://localhost

# Optional local SQLite overrides for tests/development.
# ALPHAMATE_ACCOUNT_DB_PATH=backend/data/accounts.sqlite3
# ALPHAMATE_ACCESS_DB_PATH=backend/data/access.sqlite3
# ALPHAMATE_JOURNAL_DB_PATH=backend/data/trades.sqlite3
# ALPHAMATE_REVIEW_HISTORY_DB_PATH=backend/data/review_history.sqlite3
# ALPHAMATE_EVENT_LOG_DB_PATH=backend/data/event_log.sqlite3
# Optional automatic operational event log cleanup on server startup. Minimum 7.
# ALPHAMATE_EVENT_LOG_RETENTION_DAYS=90
# Optional per-IP client event report limit. Prevents log spam against /api/client-events.
# ALPHAMATE_CLIENT_EVENT_RATE_LIMIT_PER_MINUTE=60
# Optional per-IP login limit for public auth endpoints.
# ALPHAMATE_AUTH_RATE_LIMIT_PER_MINUTE=30
# Optional auth/IP purchase verification limit for Google Play/dev purchase endpoints.
# ALPHAMATE_BILLING_RATE_LIMIT_PER_MINUTE=20
# Optional per-IP public callback limit for AdMob SSV and Google Play RTDN.
# ALPHAMATE_CALLBACK_RATE_LIMIT_PER_MINUTE=60

# Server-side admin token for protected operational event log lookup.
# Keep this outside the app/frontend and rotate it if it is exposed.
# Production readiness requires at least 32 random characters.
# ALPHAMATE_ADMIN_TOKEN=replace_with_long_random_admin_token
# Optional per-IP admin operational log API limit.
# ALPHAMATE_ADMIN_RATE_LIMIT_PER_MINUTE=30

# Public HTTPS privacy policy URL required before production release.
# ALPHAMATE_PRIVACY_POLICY_URL=https://your-domain.example/privacy

# Future production login/payment/ad verification values.
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=
# KAKAO_REDIRECT_URI=
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
# NAVER_REDIRECT_URI=
# ALPHAMATE_OAUTH_TIMEOUT_SECONDS=8
# GOOGLE_PLAY_PACKAGE_NAME=
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
# GOOGLE_PLAY_SERVICE_ACCOUNT_FILE=
# GOOGLE_PLAY_RTDN_SHARED_TOKEN=replace_with_pubsub_push_shared_secret
# GOOGLE_PLAY_RTDN_OIDC_AUDIENCE=https://your-api.example.com/api/journal/google-play-rtdn
# GOOGLE_PLAY_RTDN_OIDC_EMAIL=pubsub-push@your-project.iam.gserviceaccount.com
# GOOGLE_PLAY_BASIC_REVIEW_30_ID=basic_review_30
# GOOGLE_PLAY_BASIC_REVIEW_100_ID=basic_review_100
# GOOGLE_PLAY_ADVANCED_REVIEW_5_ID=advanced_review_5
# GOOGLE_PLAY_ADVANCED_REVIEW_10_ID=advanced_review_10
# GOOGLE_PLAY_PRO_MONTHLY_LAUNCH_ID=pro_monthly_launch
# GOOGLE_PLAY_PRO_MONTHLY_ID=pro_monthly
# ADMOB_REWARDED_AD_UNIT_ID=ca-app-pub-0000000000000000/0000000000
# ADMOB_SSV_KEY_URL=https://www.gstatic.com/admob/reward/verifier-keys.json
