# AlphaMate backend environment example.
# Copy this to .env only on the server/development machine and fill real values there.
# Never put real API keys or secrets in Git.

# development | production
ALPHAMATE_ENV=development

# Server-side only. Do not expose this through VITE_* variables.
OPENAI_API_KEY=replace_with_server_secret
OPENAI_BASIC_REVIEW_MODEL=gpt-5.4-mini
OPENAI_ADVANCED_REVIEW_MODEL=gpt-5.5

# Local development only. These are ignored when ALPHAMATE_ENV=production.
ALPHAMATE_ALLOW_DEV_ACCESS=true
ALPHAMATE_DEV_AUTH_TOKEN=dev-token
ALPHAMATE_DEV_AD_REWARD_TOKEN=dev-ad-reward
ALPHAMATE_DEV_PRO_ENTITLEMENT_TOKEN=dev-pro-entitlement
ALPHAMATE_ALLOW_ADVANCED_TICKET_FOR_BASIC=false

# Optional local SQLite overrides for tests/development.
# ALPHAMATE_ACCOUNT_DB_PATH=backend/data/accounts.sqlite3
# ALPHAMATE_ACCESS_DB_PATH=backend/data/access.sqlite3
# ALPHAMATE_JOURNAL_DB_PATH=backend/data/trades.sqlite3

# Future production login/payment/ad verification values.
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=
# KAKAO_REDIRECT_URI=
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
