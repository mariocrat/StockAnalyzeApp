{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "release:check": "node scripts/validate-release-env.js",
    "release:report": "node scripts/owner-release-report.js",
    "test:android-branding": "node --test scripts/android-branding.test.js",
    "test:android-billing": "node --test scripts/android-billing-version.test.js",
    "test:mobile-billing": "node --test scripts/mobile-billing-policy.test.js",
    "test:mobile-admob": "node --test scripts/mobile-admob-policy.test.js",
    "test:client-events": "node --test scripts/client-event-log.test.js",
    "test:api-errors": "node --test scripts/api-error-request-id.test.js",
    "test:oauth-app-return": "node --test scripts/oauth-app-return.test.js",
    "test:app-navigation": "node --test scripts/app-navigation.test.js",
    "test:ai-idempotency": "node --test scripts/ai-review-idempotency.test.js",
    "test:ai-format": "node --test scripts/ai-review-format.test.js",
    "test:splash-loading": "node --test scripts/splash-loading-policy.test.js",
    "test:chart-layout": "node --test scripts/chart-layout.test.js",
    "test:journal-mobile-ux": "node --test scripts/journal-mobile-ux.test.js",
    "test:review-selection": "node --test scripts/review-trade-selection.test.js",
    "test:user-messages": "node --test scripts/user-message.test.js",
    "test:release-env": "node --test scripts/validate-release-env.test.js",
    "test:mobile-bundle": "node --test scripts/validate-mobile-bundle.test.js",
    "mobile:build": "vite build --mode release && node scripts/validate-mobile-bundle.js && npx cap sync android",
    "mobile:release:check": "npm run release:report && npm run mobile:build",
    "mobile:release:aab": "npm run mobile:release:check && cd android && gradlew.bat bundleRelease",
    "mobile:add:android": "npx cap add android",
    "mobile:open:android": "npx cap open android",
    "mobile:sync": "npx cap sync android"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/status-bar": "^8.0.0",
    "axios": "^1.16.0",
    "capacitor-plugin-cdv-purchase": "^13.17.2",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  }
}
