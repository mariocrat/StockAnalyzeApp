# AlphaMate frontend/Android release environment template.
# Copy this to frontend/.env on the build machine only.
# Do not put OpenAI API keys, Kakao/Naver client secrets, or server admin tokens here.

VITE_ALPHAMATE_ENV=production
VITE_APP_NAME=AlphaMate
VITE_ENABLE_DEV_TOOLS=false

# Use your deployed HTTPS backend.
VITE_API_BASE=https://your-api.example.com

# Public OAuth client values used to open login pages.
# Provider secrets belong only in the backend release env file.
VITE_KAKAO_REST_API_KEY=
VITE_KAKAO_REDIRECT_URI=https://your-api.example.com/api/auth/kakao/callback
VITE_NAVER_CLIENT_ID=
VITE_NAVER_REDIRECT_URI=https://your-api.example.com/api/auth/naver/callback

# Mobile AdMob ad units. Use real production units, not Google test units.
VITE_ADMOB_ANDROID_APP_ID=ca-app-pub-0000000000000000~0000000000
VITE_ADMOB_REWARDED_AD_UNIT_ID=ca-app-pub-0000000000000000/0000000000
VITE_ADMOB_REVIEW_HISTORY_INTERSTITIAL_AD_UNIT_ID=ca-app-pub-0000000000000000/1111111111
VITE_ADMOB_RESUME_INTERSTITIAL_AD_UNIT_ID=ca-app-pub-0000000000000000/2222222222
VITE_ADMOB_CHART_DETAIL_INTERSTITIAL_AD_UNIT_ID=ca-app-pub-0000000000000000/3333333333
VITE_ADMOB_BANNER_AD_UNIT_ID=ca-app-pub-0000000000000000/1111111111

# Google Play Billing. Must match Android applicationId and backend GOOGLE_PLAY_PACKAGE_NAME.
VITE_GOOGLE_PLAY_PACKAGE_NAME=com.mariocrat.stockanalyze

# Optional Android launcher label override.
ALPHAMATE_ANDROID_APP_NAME=AlphaMate

# Android release version. Increase version code for every Play Store upload.
ALPHAMATE_ANDROID_VERSION_CODE=1
ALPHAMATE_ANDROID_VERSION_NAME=1.0.0

# Android release signing. Keep the keystore and passwords outside Git.
ALPHAMATE_ANDROID_KEYSTORE_FILE=D:/secure/alphamate/alphamate-upload.jks
ALPHAMATE_ANDROID_KEYSTORE_PASSWORD=
ALPHAMATE_ANDROID_KEY_ALIAS=alphamate-upload
ALPHAMATE_ANDROID_KEY_PASSWORD=
