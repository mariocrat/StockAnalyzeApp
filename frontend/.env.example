# AlphaMate frontend environment example.
# Copy this to frontend/.env for local frontend development.
# Do not put OpenAI API keys or server secrets here.

VITE_API_BASE=http://127.0.0.1:8002
VITE_APP_NAME=AlphaMate
# Optional Android launcher label override. Defaults to VITE_APP_NAME.
# ALPHAMATE_ANDROID_APP_NAME=AlphaMate

# development | production
VITE_ALPHAMATE_ENV=development

# Mobile/Play Store builds should use your HTTPS backend and disable dev tools.
# VITE_API_BASE=https://your-api.example.com
# VITE_ALPHAMATE_ENV=production
# VITE_ENABLE_DEV_TOOLS=false
# Before creating a release build, run `npm run release:check`.

# Local development helpers only.
# Production builds hide development login/purchase controls by default.
VITE_ENABLE_DEV_TOOLS=true
# QA APK only. Keep false or unset for ordinary local and release builds.
VITE_QA_ADVANCED_COMPARISON=false
VITE_DEV_AUTH_TOKEN=dev-token
VITE_DEV_AD_REWARD_TOKEN=dev-ad-reward
VITE_DEV_ACCESS_PLAN=free
VITE_DEV_PRO_ENTITLEMENT_TOKEN=dev-pro-entitlement

# Public OAuth client values used only to open provider login pages.
# Provider secrets still belong only in the backend .env / secret manager.
# VITE_KAKAO_REST_API_KEY=
# VITE_KAKAO_REDIRECT_URI=http://127.0.0.1:5174/?view=journal&oauth_provider=kakao
# VITE_NAVER_CLIENT_ID=
# VITE_NAVER_REDIRECT_URI=http://127.0.0.1:5174/?view=journal&oauth_provider=naver

# Mobile AdMob ads.
# Development builds use Google's Android rewarded test ad unit if this is empty.
# Production builds should set real ad units.
# The rewarded ad unit should also have SSV configured in AdMob.
# VITE_ADMOB_ANDROID_APP_ID=ca-app-pub-0000000000000000~0000000000
# VITE_ADMOB_REWARDED_AD_UNIT_ID=ca-app-pub-0000000000000000/0000000000
# VITE_ADMOB_REVIEW_HISTORY_INTERSTITIAL_AD_UNIT_ID=ca-app-pub-0000000000000000/1111111111
# VITE_ADMOB_APP_OPEN_AD_UNIT_ID=ca-app-pub-0000000000000000/2222222222
# VITE_ADMOB_CHART_DETAIL_INTERSTITIAL_AD_UNIT_ID=ca-app-pub-0000000000000000/3333333333
# VITE_ADMOB_BANNER_AD_UNIT_ID=ca-app-pub-0000000000000000/1111111111

# Google Play Billing.
# Must match the Android applicationId and backend GOOGLE_PLAY_PACKAGE_NAME.
VITE_GOOGLE_PLAY_PACKAGE_NAME=com.mariocrat.stockanalyze

# Android release signing.
# Keep the real keystore file and passwords outside Git.
# Increase ALPHAMATE_ANDROID_VERSION_CODE every time you upload a new Play Store build.
# ALPHAMATE_ANDROID_VERSION_CODE=1
# ALPHAMATE_ANDROID_VERSION_NAME=1.0.0
# ALPHAMATE_ANDROID_KEYSTORE_FILE=D:\secure\alphamate-upload.jks
# ALPHAMATE_ANDROID_KEYSTORE_PASSWORD=
# ALPHAMATE_ANDROID_KEY_ALIAS=alphamate-upload
# ALPHAMATE_ANDROID_KEY_PASSWORD=
